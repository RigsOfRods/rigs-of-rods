#: system/AppCommandLine.cpp:166
msgid ""
"--help (this)\n"
"-map <map> (loads map on startup)\n"
"-pos <Vect> (overrides spawn position)\n"
"-rot <float> (overrides spawn rotation)\n"
"-truck <truck> (loads truck on startup)\n"
"-truckconfig <section>\n"
"-enter (player enters the selected truck)\n"
"-resume loads previous autosave\n"
"-checkcache forces cache update\n"
"-version shows the version information\n"
"-joinserver=<server>:<port> (join multiplayer server)\n"
"-runscript <filename> (load script, can be repeated)\n"
"For example: RoR.exe -map simple2 -pos '518 0 518' -rot 45 -truck semi.truck "
"-enter"
msgstr ""
"--help (ini)\\\n"
"-map <map> (memuat peta saat startup)\\\n"
"-pos <Vect> (mengganti posisi spawn)\\\n"
"-rot <float> (mengganti rotasi spawn)\\\n"
"-truck <truck> (memuat truk saat startup)\\\n"
"-truckconfig <section>\\\n"
"-enter (pemain masuk ke truk yang dipilih)\\\n"
"-resume memuat autosave sebelumnya\\\n"
"-checkcache memaksa pembaruan cache\\\n"
"-version menampilkan info versi\\\n"
"-joinserver=<server>:<port> (bergabung ke server multipemain)\\\n"
"-runscript <filename> (memuat skrip, dapat diulang)\\\n"
"Contoh: RoR.exe -map simple2 -pos '518 0 518' -rot 45 -truck semi.truck -"
"enter"


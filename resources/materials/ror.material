material tracks/debug/collision/box
{
    technique
    {
        pass
        {
			depth_bias 20
			lighting off
			//depth_check off
            cull_hardware none 
            scene_blend alpha_blend
            depth_write off
            texture_unit
            {
                colour_op_ex source1 src_manual src_current 0 1 1
                alpha_op_ex source1 src_manual src_current 0.5
            }
        } 
    }
}


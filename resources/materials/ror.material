}


material tracks/trigger/transredsel
{
	technique
	{
		pass
		{
			lighting off
			//depth_check off
			cull_hardware none
			scene_blend alpha_blend
			depth_write off
			texture_unit
			{
				colour_op_ex source1 src_manual src_current 1 0 0
				alpha_op_ex source1 src_manual src_current 0.5
			}
		}
	}
}


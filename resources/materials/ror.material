material tracks/abflame
{
	receive_shadows off
	technique
	{
		pass
		{
			lighting off
			scene_blend alpha_blend
			alpha_rejection greater 2
			depth_write off
     	    cull_hardware none
		    
			texture_unit
			{
				texture abflame.dds
			}
		}
	}
}

material tracks/skyboxcol
{
    technique
    {
        pass
        {
            fog_override true
            lighting off
            depth_write off

            texture_unit
            {
                texture cloudy_noon.dds cubic
                tex_address_mode clamp
            }
        }
    }
}


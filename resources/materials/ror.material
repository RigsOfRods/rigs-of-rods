material metal
{
	technique
	{
		pass
		{

			texture_unit
			{
				colour_op_ex modulate src_manual src_current 0.5 0.5 0.5 0.0 0.0
			}
		}
	}
}


material road2: RoR/Managed_Mats/BaseDiffuse
{
	set $diffuse_tex road2.dds
}




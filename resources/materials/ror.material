import * from "managed_mats.material"


material tracks/bigsign/empty
{
	technique
	{
		pass
		{
			scene_blend alpha_blend
			alpha_rejection greater 0
			cull_hardware none

			texture_unit
			{
				texture bigsign_empty.dds
			}
		}
	}
}

material tracks/bigsign/town
{
	technique
	{
		pass
		{
			scene_blend alpha_blend
			alpha_rejection greater 0
			cull_hardware none
			

			texture_unit
			{
				texture bigsign_town.dds
			}
		}
	}
}


material chp: RoR/Managed_Mats/BaseDiffuse
{
	set $diffuse_tex chp.dds
}


material tracks/EnvMapDebug
{
	receive_shadows off
	technique
	{
		pass
		{
			fog_override true
			lighting off
			depth_write off
			depth_check off
			
			cull_hardware none

			texture_unit
			{
				texture EnvironmentTexture cubic
			}
		}
	}
}


material mouse
{
	technique
	{

//Water

material tracks/endlessbasicwater
{
	receive_shadows off 
	technique
	{
		pass
		{
		   ambient 0.5 0.5 0.5
		   //specular 0.5 0.5 1.0 10.0
		   scene_blend modulate
		   // double-sided
		   cull_hardware none
		   
		   depth_write off
		   texture_unit
		   {
			  texture water.dds
		   }
		 }
		pass
		{
		   ambient 0.3 0.3 0.3
		   specular 0.5 0.5 1.0 10.0
		   scene_blend add
		   // double-sided
		   cull_hardware none
		   
		   depth_write off
		   texture_unit
		   {
			  texture water.dds
		   }
		 }
	}
}

material tracks/basicwater
{
	receive_shadows off 
	technique
	{
		pass
		{
		   ambient 0.5 0.5 0.5
		   //specular 0.5 0.5 1.0 10.0
		   scene_blend modulate
		   // double-sided
		   cull_hardware none
		   
		   depth_write off
		   texture_unit
		   {
			  texture water.dds
			  scroll_anim .01 .01
		   }
		 }
		pass
		{
		   ambient 0.3 0.3 0.3
		   specular 0.5 0.5 1.0 10.0
		   scene_blend add
		   // double-sided
		   cull_hardware none
		   
		   depth_write off
		   texture_unit
		   {
			  texture water.dds
			  scroll_anim -.01 -.01
		   }
		 }
	}
}

material tracks/otherbasicwater
{
	receive_shadows off 
   technique
   {
      pass
      {
         ambient 0.5 0.5 0.5
         scene_blend alpha_blend
         depth_write off

         texture_unit
         {
            texture water.dds
			alpha_op_ex source1 src_manual src_manual 0.5 0.5
            scroll_anim 0.01 0
         }

         texture_unit
         {
            texture water.dds
			alpha_op_ex source1 src_manual src_manual 0.5 0.5
            wave_xform scroll_y sine 0 0.1 0 0.5
         }
      }
   }
} 

